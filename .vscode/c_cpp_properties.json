{   
    "configurations": [
        {
            "name": "x86_64-elf-gcc",
            "compilerPath": "/usr/local/bin/x86_64-elf-gcc",
            "cStandard": "c99",
            "intelliSenseMode": "gcc-x86",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/deps/include"
            ],
            "defines": [
                "__ELF__"
            ],
            "compilerArgs": [
                "-std=c99",
                "-ffreestanding",
                "-nostdlib",
                "-DDEBUG"
            ]
        }
    ],
    "version": 4
}